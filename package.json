{
  "name": "javi-ai",
  "version": "1.2.0",
  "description": "AI development layer installer — skills, orchestrators, and configs for Claude, OpenCode, Gemini, Qwen, Codex, and Copilot",
  "type": "module",
  "bin": {
    "javi-ai": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.tsx",
    "start": "node dist/index.js",
    "lint": "biome check --diagnostic-level=error src/ --reporter=summary",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "package:check": "npm pack --dry-run --json --cache /tmp/javi-ai-npm-pack-cache > /tmp/javi-ai-pack.json && node scripts/verify-package-contents.mjs /tmp/javi-ai-pack.json"
  },
  "keywords": [
    "ai",
    "claude",
    "opencode",
    "skills",
    "developer-tools"
  ],
  "author": "JNZader",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JNZader/javi-ai"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.4",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "meow": "^14.1.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "configs/",
    "upstream/",
    "delta/",
    "own/",
    "README.md",
    "LICENSE*"
  ]
}
